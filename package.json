{
  "packageManager": "pnpm@8.9.0",
  "name": "@morpheus4j/monorepo",
  "scripts": {
    "pre-commit": "pnpm run --filter \"@morpheus4j/*\" pre-commit",
    "build": "npx turbo build",
    "dev": "npx turbo dev",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky install",
    "publish-packages": "turbo run build lint && npx changeset && npx changeset version && npx changeset publish",
    "ch:version": "npx changeset version",
    "ch:release": "npx changeset publish",
    "postinstall": "npx manypkg check",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "dependencies": {
    "@changesets/cli": "2.27.1",
    "@manypkg/cli": "latest",
    "@morpheus4j/eslint-config-custom": "0.0.0",
    "@morpheus4j/tsconfig": "0.0.0",
    "eslint": "^8.42.0",
    "husky": "9.0.6",
    "prettier": "^3.0.0"
  }
}
